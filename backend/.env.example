# Copy to backend/.env (not the repo root) and fill in. The real-flow smoke script loads this file.
# Changes to .env require restarting the backend (or uvicorn --reload picks them up
# automatically on next request after a file change).

# LiteLLM provider credentials. Only the provider matching your chosen models is required.
# Defaults below use gemini/* models, so GEMINI_API_KEY is the relevant one.
GEMINI_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# Optional model overrides. Defaults are listed inline.
# Router intent classifier — small/fast model is sufficient.
# PAPERHUB_ROUTER_MODEL=gemini/gemini-2.5-flash
# Chitchat agent — small/fast model is fine.
# PAPERHUB_CHITCHAT_MODEL=gemini/gemini-2.5-flash
# Research Agent (paper_search + paper_qa map + synthesize) — flagship model recommended
# because of multi-paper synthesis. Both paper_search and paper_qa use this setting.
# To use different models for paper_search vs paper_qa, add PAPERHUB_PAPER_SEARCH_MODEL
# as a separate setting (future extension — not yet implemented).
# PAPERHUB_PAPER_QA_MODEL=gemini/gemini-2.5-pro
# Embedding model (sentence-transformers, local CPU/GPU). Used for paper chunks + queries.
# PAPERHUB_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
# Reranker (cross-encoder, local). Reorders Chroma candidates before passing to the LLM.
# PAPERHUB_RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# Workspace dir for the SQLite db + any future per-run artefacts.
# PAPERHUB_WORKSPACE=./workspace

# Semantic Scholar API key for the Research Agent's find_related_papers tool
# (citation-graph navigation: cites / cited_by / similar). Optional — the
# public endpoint works without a key, but is rate-limited to 100 requests
# per 5 minutes (shared across all unauthenticated clients). Get a free key:
# https://www.semanticscholar.org/product/api#api-key — authenticated tier
# raises the limit to ~1 req/sec.
# PAPERHUB_SEMANTIC_SCHOLAR_API_KEY=
